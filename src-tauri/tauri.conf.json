{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "aScrobble",
  "version": "1.0.0",
  "identifier": "dev.ascrobble.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "aScrobble — Apple Music to Last.fm",
        "width": 900,
        "height": 680,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ThisCrashesYouOnPhone/aScrobble/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/worker.js"
    ]
  }
}
