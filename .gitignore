# Dependencies
node_modules/
worker/node_modules/

# Build outputs
dist/
worker/dist/
src-tauri/target/
src-tauri/gen/

# The bundled worker.js is regenerated by `npm run build:worker` from
# the TypeScript source in worker/src/. We do commit it though, since
# the desktop app needs it bundled as a Tauri resource and not every
# downstream user will want to run the worker build chain.
# !src-tauri/resources/worker.js

# IDE / OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env files (should never be committed)
.env
.env.local
.env.*.local

# Tauri
src-tauri/.cargo/

# Wrangler local state
worker/.wrangler/
worker/.dev.vars
