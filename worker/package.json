{
  "name": "ascrobble-worker",
  "version": "1.0.0",
  "private": true,
  "description": "Cloudflare Worker that polls Apple Music and scrobbles to Last.fm",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --target=es2022 --outfile=dist/worker.js",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250404.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4",
    "wrangler": "^3.90.0"
  }
}
